<ui:UiWindow
    x:Class="GenshinLyreMidiPlayer.WPF.Views.MainWindowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"

    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:modern="http://schemas.modernwpf.com/2019"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:modernWpf="clr-namespace:GenshinLyreMidiPlayer.WPF.ModernWPF"
    xmlns:viewModels="clr-namespace:GenshinLyreMidiPlayer.WPF.ViewModels"

    d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}"

    Title="{Binding Title}"
    Height="860" Width="960" MinWidth="680" MinHeight="560"
    Background="#1D1A16"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Title bar ─────────────────────────────────── -->
        <ui:TitleBar Grid.Row="0" Title="" Background="#252019">
            <ui:TitleBar.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Brand mark in sidebar width -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Width="18" Height="18" Margin="0,0,6,0">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#C9A93C" StrokeThickness="1.9"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M6 5.5C6 12 7.5 17 9.5 19.5" />
                                <Path Stroke="#C9A93C" StrokeThickness="1.9"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M18 5.5C18 12 16.5 17 14.5 19.5" />
                                <Path Stroke="#C9A93C" StrokeThickness="1.9" Opacity="0.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M9 6.5h6 M8.4 10h7.2 M8.6 13.5h6.8" />
                            </Canvas>
                        </Viewbox>
                    </StackPanel>

                    <!-- Search + update link -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="4,0">
                        <ui:Hyperlink
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            Command="{s:Action NavigateToSettings}"
                            Visibility="{Binding ShowUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                            New update!
                        </ui:Hyperlink>
                        <ui:AutoSuggestBox
                            MinWidth="200" MaxWidth="280"
                            PlaceholderText="Search songs…"
                            TextChanged="{s:Action SearchSong}"
                            ItemsSource="{Binding PlaylistView.TrackTitles}"
                            Text="{Binding PlaylistView.FilterText}" />
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
            <ui:TitleBar.Tray>
                <ui:NotifyIcon FocusOnLeftClick="True" MenuOnRightClick="True" TooltipText="Windsong Lyre MIDI Player">
                    <ui:NotifyIcon.Menu>
                        <ContextMenu>
                            <ui:MenuItem Command="{s:Action PlayPause, Target=PlayerView}" Header="Play / Pause" SymbolIcon="Play16" />
                            <ui:MenuItem Command="{s:Action Next,      Target=PlayerView}" Header="Next"        SymbolIcon="Next16" />
                        </ContextMenu>
                    </ui:NotifyIcon.Menu>
                </ui:NotifyIcon>
            </ui:TitleBar.Tray>
        </ui:TitleBar>

        <!-- ── App body ──────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="86" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ───────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="#1D1A16" LastChildFill="True">

                <!-- Footer: Settings -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
                    <RadioButton
                        Tag="Settings" Content="&#xE713;"
                        GroupName="Nav"
                        IsChecked="{Binding ActiveTab, Converter={StaticResource StrEq}, ConverterParameter=settings, Mode=OneWay}"
                        Command="{s:Action ShowSettings}"
                        Style="{StaticResource NavItemStyle}"
                        Width="70" Height="66" />
                </StackPanel>

                <!-- Top: main nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,16,0,0">
                    <RadioButton
                        Tag="Player"   Content="&#xE768;"
                        GroupName="Nav"
                        IsChecked="{Binding ActiveTab, Converter={StaticResource StrEq}, ConverterParameter=player, Mode=OneWay}"
                        Command="{s:Action ShowPlayer}"
                        Style="{StaticResource NavItemStyle}"
                        Width="70" Height="66" />

                    <RadioButton
                        Tag="Playlist" Content="&#xE8FD;"
                        GroupName="Nav"
                        IsChecked="{Binding ActiveTab, Converter={StaticResource StrEq}, ConverterParameter=playlist, Mode=OneWay}"
                        Command="{s:Action ShowPlaylist}"
                        Style="{StaticResource NavItemStyle}"
                        Width="70" Height="66" />

                    <RadioButton
                        Tag="Sheet"    Content="&#xE8A5;"
                        GroupName="Nav"
                        IsChecked="{Binding ActiveTab, Converter={StaticResource StrEq}, ConverterParameter=sheet, Mode=OneWay}"
                        Command="{s:Action ShowSheet}"
                        Style="{StaticResource NavItemStyle}"
                        Width="70" Height="66" />

                    <RadioButton
                        Tag="Editor"   Content="&#xE70F;"
                        GroupName="Nav"
                        IsChecked="{Binding ActiveTab, Converter={StaticResource StrEq}, ConverterParameter=editor, Mode=OneWay}"
                        Command="{s:Action ShowEditor}"
                        Style="{StaticResource NavItemStyle}"
                        Width="70" Height="66" />

                    <RadioButton
                        Tag="Convert"  Content="&#xE714;"
                        GroupName="Nav"
                        IsChecked="{Binding ActiveTab, Converter={StaticResource StrEq}, ConverterParameter=convert, Mode=OneWay}"
                        Command="{s:Action ShowConverter}"
                        Style="{StaticResource NavItemStyle}"
                        Width="70" Height="66" />
                </StackPanel>
            </DockPanel>

            <!-- ── Content area ───────────────────────────── -->
            <Border Grid.Column="1" Background="#252019" CornerRadius="12,0,0,0">
                <modernWpf:AnimatedContentControl
                    Margin="24,20,24,20"
                    s:View.Model="{Binding ActiveItem}" />
            </Border>
        </Grid>
    </Grid>
</ui:UiWindow>
