<UserControl
    x:Class="GenshinLyreMidiPlayer.WPF.Views.PlaylistView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:componentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:modernWpf="clr-namespace:GenshinLyreMidiPlayer.WPF.ModernWPF"
    xmlns:viewModels="clr-namespace:GenshinLyreMidiPlayer.WPF.ViewModels"
    xmlns:midi="clr-namespace:GenshinLyreMidiPlayer.Data.Midi;assembly=GenshinLyreMidiPlayer.Data"
    d:DataContext="{d:DesignInstance Type=viewModels:PlaylistViewModel}">

    <UserControl.Resources>
        <modernWpf:TrackGroupKeyConverter x:Key="TrackGroupKeyConverter" />
        <CollectionViewSource x:Key="Tracks" Source="{Binding FilteredTracks}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Title" Converter="{StaticResource TrackGroupKeyConverter}" />
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <componentModel:SortDescription PropertyName="Title" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <DataTemplate x:Key="TrackRowTemplate" DataType="midi:MidiFile">
            <!-- NOTE: No Background attribute here — local values beat Style triggers in WPF.
                 The base Background is set via Style Setter so DataTriggers can override it. -->
            <Border CornerRadius="9" Padding="14,10" Margin="0,2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <!-- Hover -->
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Bg3Brush}" />
                            </DataTrigger>
                            <!-- Selected (comes after hover so it wins) -->
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Lyre icon badge -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                            Background="{StaticResource AccentSoftBrush}" Margin="0,0,10,0">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#C9A93C" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M6 5.5C6 12 7.5 17 9.5 19.5" />
                                <Path Stroke="#C9A93C" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M18 5.5C18 12 16.5 17 14.5 19.5" />
                                <Path Stroke="#C9A93C" StrokeThickness="1.8" Opacity="0.75"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M9 6.5h6 M8.4 10h7.2 M8.6 13.5h6.8" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Title + duration -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title, Mode=OneTime}"
                                   FontSize="13.5" FontWeight="Medium"
                                   Foreground="{StaticResource InkBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Duration, Mode=OneWay, StringFormat=m\\:ss}"
                                   FontSize="11.5" Foreground="{StaticResource Ink3Brush}" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Position badge -->
                    <Border Grid.Column="2" CornerRadius="5" Padding="6,2"
                            Background="{StaticResource Bg3Brush}" VerticalAlignment="Center"
                            Visibility="{Binding Position, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding Position}" FontSize="11"
                                   Foreground="{StaticResource Ink4Brush}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Page header ────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="LIBRARY" Style="{StaticResource EyebrowStyle}" />
            <TextBlock Text="Playlist" Style="{StaticResource PageTitleStyle}" />
        </StackPanel>

        <!-- ── Toolbar ─────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource WinPanelSm}" Padding="14,10" Margin="0,0,0,12">
            <DockPanel>
                <!-- Open file -->
                <Button DockPanel.Dock="Left" Command="{s:Action OpenFile}"
                        Style="{StaticResource AccentBtn}" Height="34" Padding="14,0"
                        Margin="0,0,10,0" ToolTip="Add files to playlist">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Add files" FontSize="12.5" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Current song label -->
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="{StaticResource Ink2Brush}" FontSize="12.5">
                    <Run Text="Now:" Foreground="{StaticResource Ink4Brush}" />
                    <Run Text="{Binding OpenedFile.Title, Mode=OneWay, FallbackValue='—'}" />
                </TextBlock>

                <!-- Action buttons on the right -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{s:Action ToggleShuffle}"
                            Style="{StaticResource IconBtn}" Margin="4,0,0,0" ToolTip="Shuffle">
                        <TextBlock Text="&#xE14B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{Binding ShuffleStateColor}" />
                    </Button>
                    <Button Command="{s:Action ToggleLoop}"
                            Style="{StaticResource IconBtn}" Margin="4,0,0,0" ToolTip="Loop mode">
                        <TextBlock Text="{Binding LoopStateString}" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                    <Button Command="{s:Action RemoveTrack}"
                            Style="{StaticResource GhostBtn}" Height="34" Padding="10,0"
                            Margin="8,0,0,0" Foreground="{StaticResource Ink3Brush}" ToolTip="Remove selected">
                        Remove
                    </Button>
                    <Button Command="{s:Action ClearPlaylist}"
                            Style="{StaticResource GhostBtn}" Height="34" Padding="10,0"
                            Margin="4,0,0,0" Foreground="{StaticResource DangerBrush}" ToolTip="Clear all">
                        Clear
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Track list ──────────────────────────────────── -->
        <ListView
            Grid.Row="2"
            ItemsSource="{Binding Source={StaticResource Tracks}}"
            ItemTemplate="{StaticResource TrackRowTemplate}"
            VirtualizingPanel.IsVirtualizingWhenGrouping="True"
            VirtualizingPanel.VirtualizationMode="Recycling"
            MouseDoubleClick="{s:Action OnFileChanged}"
            SelectedItem="{Binding SelectedFile}"
            Background="Transparent"
            BorderThickness="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate DataType="CollectionViewGroup">
                            <Border Padding="4,14,4,6">
                                <TextBlock Text="{Binding Name, Mode=OneTime}"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="22" Foreground="{StaticResource AccentBrightBrush}" />
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
        </ListView>
    </Grid>
</UserControl>
