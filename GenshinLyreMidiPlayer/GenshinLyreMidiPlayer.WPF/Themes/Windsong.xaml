<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wm="clr-namespace:GenshinLyreMidiPlayer.WPF.ModernWPF">

    <!-- ── Converters ───────────────────────────────────────── -->
    <wm:StringEqualsConverter x:Key="StrEq" />

    <!-- ── Brushes ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Bg0Brush"        Color="#1D1A16" />
    <SolidColorBrush x:Key="Bg1Brush"        Color="#252019" />
    <SolidColorBrush x:Key="Bg2Brush"        Color="#2C2820" />
    <SolidColorBrush x:Key="Bg3Brush"        Color="#363028" />
    <SolidColorBrush x:Key="BgHoverBrush"    Color="#403A30" />

    <SolidColorBrush x:Key="AccentBrush"     Color="#C9A93C" />
    <SolidColorBrush x:Key="AccentBrightBrush" Color="#D6BC5C" />
    <SolidColorBrush x:Key="AccentDeepBrush" Color="#A68A22" />
    <SolidColorBrush x:Key="AccentInkBrush"  Color="#2E2506" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#28C9A93C" />
    <SolidColorBrush x:Key="AccentLineBrush" Color="#6BC9A93C" />

    <SolidColorBrush x:Key="InkBrush"        Color="#EDE9DC" />
    <SolidColorBrush x:Key="Ink2Brush"       Color="#BDB49A" />
    <SolidColorBrush x:Key="Ink3Brush"       Color="#8A8270" />
    <SolidColorBrush x:Key="Ink4Brush"       Color="#6A6358" />

    <SolidColorBrush x:Key="LineBrush"       Color="#505A5040" />
    <SolidColorBrush x:Key="LineSoftBrush"   Color="#305A5040" />
    <SolidColorBrush x:Key="LineStrongBrush" Color="#886A6358" />
    <SolidColorBrush x:Key="DangerBrush"     Color="#C85430" />

    <!-- ── Typography ────────────────────────────────────────── -->
    <FontFamily x:Key="DisplayFont">Georgia, 'Palatino Linotype', 'Times New Roman', serif</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas, 'Courier New', monospace</FontFamily>

    <!-- ── Text styles ───────────────────────────────────────── -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize"    Value="34" />
        <Setter Property="FontWeight"  Value="Normal" />
        <Setter Property="Foreground"  Value="{StaticResource InkBrush}" />
        <Setter Property="Margin"      Value="0,0,0,2" />
    </Style>

    <Style x:Key="EyebrowStyle" TargetType="TextBlock">
        <Setter Property="FontSize"    Value="10.5" />
        <Setter Property="FontWeight"  Value="SemiBold" />
        <Setter Property="Foreground"  Value="{StaticResource Ink4Brush}" />
    </Style>

    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"    Value="14" />
        <Setter Property="FontWeight"  Value="SemiBold" />
        <Setter Property="Foreground"  Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"    Value="13" />
        <Setter Property="Foreground"  Value="{StaticResource InkBrush}" />
        <Setter Property="FontFamily"  Value="{StaticResource BodyFont}" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"    Value="12" />
        <Setter Property="Foreground"  Value="{StaticResource Ink3Brush}" />
        <Setter Property="FontFamily"  Value="{StaticResource BodyFont}" />
    </Style>

    <!-- ── WinPanel (card surface) ───────────────────────────── -->
    <Style x:Key="WinPanel" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource Bg2Brush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource LineSoftBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="14" />
    </Style>

    <Style x:Key="WinPanelSm" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource Bg2Brush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource LineSoftBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="9" />
    </Style>

    <!-- ── Button base template ─────────────────────────────── -->
    <ControlTemplate x:Key="WinBtnTemplate" TargetType="Button">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="9"
                Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background"   Value="{StaticResource Bg3Brush}" />
                <Setter TargetName="Root" Property="BorderBrush"  Value="{StaticResource LineStrongBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background"   Value="{StaticResource BgHoverBrush}" />
                <Setter TargetName="Root" Property="BorderBrush"  Value="{StaticResource AccentLineBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Standard button -->
    <Style x:Key="WinBtn" TargetType="Button">
        <Setter Property="Background"       Value="{StaticResource Bg2Brush}" />
        <Setter Property="Foreground"       Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="Height"           Value="38" />
        <Setter Property="Padding"          Value="16,0" />
        <Setter Property="FontFamily"       Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize"         Value="13" />
        <Setter Property="FontWeight"       Value="Medium" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="Template"         Value="{StaticResource WinBtnTemplate}" />
    </Style>

    <!-- Accent button template — overlay tint on hover keeps gradient intact -->
    <ControlTemplate x:Key="AccentBtnTemplate" TargetType="Button">
        <Border x:Name="Root" CornerRadius="9" Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}" BorderThickness="0">
            <Grid>
                <Border x:Name="HoverLayer" CornerRadius="9" Background="Transparent" />
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="HoverLayer" Property="Background" Value="#22FFFFFF" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="HoverLayer" Property="Background" Value="#28000000" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Accent (gold gradient) button -->
    <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
        <Setter Property="Foreground"      Value="{StaticResource AccentInkBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template"        Value="{StaticResource AccentBtnTemplate}" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#D6BC5C" Offset="0" />
                    <GradientStop Color="#A68A22" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost (transparent) button — subtle fill + border on hover -->
    <ControlTemplate x:Key="GhostBtnTemplate" TargetType="Button">
        <Border x:Name="Root" CornerRadius="9" Padding="{TemplateBinding Padding}"
                Background="Transparent" BorderThickness="0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource Bg3Brush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource BgHoverBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Ghost (no bg) button -->
    <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template"        Value="{StaticResource GhostBtnTemplate}" />
    </Style>

    <!-- Square icon button -->
    <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
        <Setter Property="Width"   Value="38" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Round play button (gold circle) -->
    <Style x:Key="PlayBtn" TargetType="Button">
        <Setter Property="Width"           Value="58" />
        <Setter Property="Height"          Value="58" />
        <Setter Property="Foreground"      Value="{StaticResource AccentInkBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Width="58" Height="58">
                        <Ellipse x:Name="Bg">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                    <GradientStop Color="#D6BC5C" Offset="0" />
                                    <GradientStop Color="#A68A22" Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#C9A93C" BlurRadius="14" ShadowDepth="0" Opacity="0.35" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.72" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Sidebar nav item (RadioButton) ─────────────────── -->
    <Style x:Key="NavItemStyle" TargetType="RadioButton">
        <Setter Property="Foreground"      Value="{StaticResource Ink3Brush}" />
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin"          Value="8,2" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <!-- Left active bar -->
                        <Border x:Name="Bar"
                                Width="3" HorizontalAlignment="Left" CornerRadius="0,3,3,0"
                                Background="{StaticResource AccentBrush}" Opacity="0" />
                        <!-- Body -->
                        <Border x:Name="Bg" CornerRadius="12" Padding="2,10">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Icon glyph string bound from Content -->
                                <TextBlock
                                    Text="{TemplateBinding Content}"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="20"
                                    TextAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}" />
                                <!-- Label from Tag -->
                                <TextBlock
                                    Text="{TemplateBinding Tag}"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="10.5"
                                    FontWeight="Medium"
                                    TextAlignment="Center"
                                    Margin="0,5,0,0"
                                    Foreground="{TemplateBinding Foreground}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bar" Property="Opacity"    Value="1" />
                            <Setter TargetName="Bg"  Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            <Setter Property="Foreground"                   Value="{StaticResource AccentBrightBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked"   Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Bg2Brush}" />
                            <Setter Property="Foreground"                   Value="{StaticResource InkBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Themed TextBox ─────────────────────────────────── -->
    <Style x:Key="WinTextBox" TargetType="TextBox">
        <Setter Property="Background"              Value="{StaticResource Bg2Brush}" />
        <Setter Property="Foreground"              Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush"             Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness"         Value="1" />
        <Setter Property="CaretBrush"              Value="{StaticResource AccentBrush}" />
        <Setter Property="SelectionBrush"          Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="Padding"                 Value="12,0" />
        <Setter Property="Height"                  Value="38" />
        <Setter Property="FontFamily"              Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize"                Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            <Setter TargetName="Root" Property="Background"   Value="{StaticResource Bg3Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Multiline variant -->
    <Style x:Key="WinTextBoxMulti" TargetType="TextBox" BasedOn="{StaticResource WinTextBox}">
        <Setter Property="Height"                  Value="Auto" />
        <Setter Property="AcceptsReturn"           Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="FontFamily"              Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize"                Value="13" />
        <Setter Property="Padding"                 Value="14,12" />
    </Style>

    <!-- ── Slider (progress bar) ─────────────────────────── -->
    <Style x:Key="SliderDecBtn" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="5" CornerRadius="999">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A68A22" Offset="0" />
                                <GradientStop Color="#D6BC5C" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderIncBtn" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="5" Background="{StaticResource Bg3Brush}" CornerRadius="999" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderThumb" TargetType="Thumb">
        <Setter Property="Width"  Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Ellipse x:Name="Dot" Width="14" Height="14" Fill="{StaticResource AccentBrightBrush}">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.45" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Dot" Property="Fill" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WinSlider" TargetType="Slider">
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="Focusable"            Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Height="24" VerticalAlignment="Center">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                              Style="{StaticResource SliderDecBtn}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SliderThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                              Style="{StaticResource SliderIncBtn}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Toggle pill (replaces ToggleSwitch in settings) ── -->
    <Style x:Key="WinToggle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="FontSize"   Value="13.5" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Cursor"     Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Pill" Width="42" Height="24" CornerRadius="12"
                                Background="{StaticResource Bg3Brush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                Margin="0,0,12,0">
                            <Ellipse x:Name="Thumb" Width="18" Height="18"
                                     HorizontalAlignment="Left" Margin="2,0,0,0"
                                     Fill="{StaticResource Ink3Brush}" />
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Pill"  Property="Background"       Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Pill"  Property="BorderBrush"      Value="Transparent" />
                            <Setter TargetName="Thumb" Property="Fill"             Value="#FAFAF5" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Thumb" Property="Margin"           Value="0,0,2,0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Track row CheckBox (compact, no pill — just a glyph check) ── -->
    <Style x:Key="TrackToggle" TargetType="CheckBox">
        <Setter Property="Foreground"  Value="{StaticResource InkBrush}" />
        <Setter Property="FontSize"    Value="13" />
        <Setter Property="FontFamily"  Value="{StaticResource BodyFont}" />
        <Setter Property="Cursor"      Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Box" Width="20" Height="20" CornerRadius="5"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                            Background="Transparent">
                        <TextBlock x:Name="Check" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentInkBrush}" Visibility="Collapsed" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box"   Property="Background"   Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Box"   Property="BorderBrush"  Value="Transparent" />
                            <Setter TargetName="Check" Property="Visibility"   Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Lyre key button (editor keyboard) ─────────────── -->
    <Style x:Key="KeyBtn" TargetType="Button">
        <Setter Property="Width"   Value="44" />
        <Setter Property="Height"  Value="44" />
        <Setter Property="Margin"  Value="2" />
        <Setter Property="Cursor"  Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" CornerRadius="8"
                            Background="{StaticResource Bg2Brush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"  Value="{StaticResource AccentSoftBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"  Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground"                     Value="{StaticResource AccentInkBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Special key (rest, duration) -->
    <Style x:Key="KeyBtnSpecial" TargetType="Button" BasedOn="{StaticResource KeyBtn}">
        <Setter Property="Foreground" Value="{StaticResource Ink3Brush}" />
        <Setter Property="Width"      Value="54" />
    </Style>

    <!-- ── Editor file-browser list item ─────────────────── -->
    <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
        <Setter Property="FontSize"    Value="12.5" />
        <Setter Property="FontFamily"  Value="{StaticResource BodyFont}" />
        <Setter Property="Padding"     Value="10,7" />
        <Setter Property="Cursor"      Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Row" CornerRadius="7" Padding="{TemplateBinding Padding}" Margin="0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="Icon" Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource Ink4Brush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{StaticResource Ink2Brush}"
                                       FontSize="{TemplateBinding FontSize}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row"  Property="Background" Value="{StaticResource Bg3Brush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row"  Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            <Setter TargetName="Icon" Property="Foreground"  Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Editor sidebar ListBox container ───────────────── -->
    <Style x:Key="FileListStyle" TargetType="ListBox">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource FileItemStyle}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

</ResourceDictionary>
