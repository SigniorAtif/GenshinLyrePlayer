<UserControl
    x:Class="GenshinLyreMidiPlayer.WPF.Views.SettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:modern="http://schemas.modernwpf.com/2019"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:theme="clr-namespace:GenshinLyreMidiPlayer.WPF.ModernWPF.Theme"
    xmlns:core="clr-namespace:GenshinLyreMidiPlayer.WPF.Core"
    xmlns:viewModels="clr-namespace:GenshinLyreMidiPlayer.WPF.ViewModels"
    xmlns:transitions="clr-namespace:GenshinLyreMidiPlayer.WPF.ModernWPF.Animation.Transitions"
    xmlns:properties="clr-namespace:GenshinLyreMidiPlayer.Data.Properties;assembly=GenshinLyrePlayer.Data"
    d:DataContext="{d:DesignInstance Type=viewModels:SettingsPageViewModel}">

    <UserControl.Resources>
        <theme:AppThemeConverter x:Key="AppThemeConverter" />
        <properties:Settings x:Key="Settings" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,16">

            <!-- ── Page header ─────────────────────────────── -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="CONFIGURATION" Style="{StaticResource EyebrowStyle}" />
                <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />
            </StackPanel>

            <!-- ══ Playback card ══════════════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Playback" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <WrapPanel>
                        <CheckBox Content="Test Mode (Speakers)"
                                  IsEnabled="{Binding CanUseSpeakers}"
                                  IsChecked="{Binding Default.UseSpeakers, Source={StaticResource Settings}}"
                                  Style="{StaticResource WinToggle}"
                                  Margin="0,0,28,10" />
                        <CheckBox Content="Transpose notes"
                                  IsChecked="{Binding Default.TransposeNotes, Source={StaticResource Settings}}"
                                  Style="{StaticResource WinToggle}"
                                  Margin="0,0,28,10" />
                        <CheckBox Content="Hold notes"
                                  IsChecked="{Binding Default.HoldNotes, Source={StaticResource Settings}}"
                                  Style="{StaticResource WinToggle}"
                                  Margin="0,0,28,10" />
                        <CheckBox Content="Merge nearby notes"
                                  IsChecked="{Binding MergeNotes}"
                                  Style="{StaticResource WinToggle}"
                                  Margin="0,0,28,10" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{Binding Key}" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                            <modern:NumberBox Value="{Binding KeyOffset}"
                                             Minimum="{Binding MinOffset}"
                                             Maximum="{Binding MaxOffset}"
                                             Width="100" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Tolerance (ms)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                            <modern:NumberBox Value="{Binding MergeMilliseconds}"
                                             IsEnabled="{Binding MergeNotes}"
                                             Width="120" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Layout & Instrument card ═════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Layout &amp; Instrument" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Keyboard Layout" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{x:Static core:Keyboard.LayoutNames}"
                                      SelectedItem="{Binding SelectedLayout}"
                                      SelectedIndex="{Binding Default.SelectedLayout, Source={StaticResource Settings}}"
                                      DisplayMemberPath="Value" MinWidth="160" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Instrument" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{x:Static core:Keyboard.InstrumentNames}"
                                      SelectedItem="{Binding SelectedInstrument}"
                                      SelectedIndex="{Binding Default.SelectedInstrument, Source={StaticResource Settings}}"
                                      DisplayMemberPath="Value" MinWidth="160" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Transpose & Speed card ═══════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Transpose &amp; Speed" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Transpose" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{x:Static viewModels:SettingsPageViewModel.TransposeNames}"
                                      SelectedItem="{Binding Transpose}"
                                      DisplayMemberPath="Value" MinWidth="160" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Playback Speed" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding MidiSpeeds}"
                                      SelectedItem="{Binding SelectedSpeed}"
                                      SelectedIndex="{Binding Default.SelectedSpeed, Source={StaticResource Settings}}"
                                      DisplayMemberPath="SpeedName" MinWidth="140" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Timer card ════════════════════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Timer" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <modern:SimpleTimePicker SelectedDateTime="{Binding DateTime}"
                                                 IsEnabled="{Binding CanChangeTime}"
                                                 Margin="0,0,10,0" />
                        <Button Command="{s:Action SetTimeToNow}" IsEnabled="{Binding CanChangeTime}"
                                Style="{StaticResource WinBtn}" Height="36" Padding="12,0" Margin="0,0,8,0"
                                Content="Now" />
                        <Button Command="{s:Action StartStopTimer}"
                                Content="{Binding TimerText}"
                                Style="{StaticResource AccentBtn}" Height="36" Padding="12,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Location card ═════════════════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Game Location" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{s:Action SetLocation}"
                                Style="{StaticResource WinBtn}" Height="36" Padding="12,0" Margin="0,0,12,0"
                                ToolTip="Browse for Genshin Impact executable">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                        </Button>
                        <TextBlock Text="{x:Static viewModels:SettingsPageViewModel.GenshinLocation}"
                                   VerticalAlignment="Center" FontSize="12.5"
                                   Foreground="{StaticResource Ink2Brush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Version card ══════════════════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Version" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Ink2Brush}">
                            v<Run Text="{Binding ProgramVersion, Mode=OneTime}" Foreground="{StaticResource InkBrush}" />
                        </TextBlock>
                        <Button Command="{s:Action CheckForUpdate}"
                                Style="{StaticResource GhostBtn}" Height="32" Padding="10,0" Margin="12,0,0,0"
                                Foreground="{StaticResource Ink3Brush}"
                                Visibility="{Binding IsCheckingUpdate, Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                        <ui:ProgressRing IsIndeterminate="True" IsEnabled="{Binding IsCheckingUpdate}"
                                         Visibility="{Binding IsCheckingUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                         Width="20" Height="20" Margin="12,0,0,0" />
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource AccentBrightBrush}" FontSize="13"
                               Visibility="{Binding NeedsUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                               Margin="0,0,0,10">
                        Update available:
                        <Hyperlink NavigateUri="{Binding LatestVersion.Url}">
                            <Run Text="{Binding LatestVersion.TagName}" />
                            <Run Text=" — " />
                            <Run Text="{Binding LatestVersion.Name}" />
                        </Hyperlink>
                    </TextBlock>
                    <StackPanel>
                        <CheckBox Content="Automatically check for updates"
                                  IsChecked="{Binding AutoCheckUpdates}"
                                  Style="{StaticResource WinToggle}" Margin="0,0,0,8" />
                        <CheckBox Content="Include beta / pre-release updates"
                                  IsChecked="{Binding IncludeBetaUpdates}"
                                  Style="{StaticResource WinToggle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Theme card ════════════════════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Appearance" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <TextBlock Text="Theme Mode" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,8" />
                    <modern:RadioButtons
                        SelectedItem="{Binding Source={x:Static modern:ThemeManager.Current}, Path=ApplicationTheme, Converter={StaticResource AppThemeConverter}}"
                        SelectionChanged="{s:Action OnThemeChanged}"
                        SelectedIndex="{Binding Default.AppTheme, Source={StaticResource Settings}}">
                        <modern:RadioButtons.ItemsSource>
                            <theme:AppThemes />
                        </modern:RadioButtons.ItemsSource>
                    </modern:RadioButtons>
                    <TextBlock Text="Transition Style" Style="{StaticResource EyebrowStyle}" Margin="0,16,0,8" />
                    <ComboBox SelectedItem="{Binding Transition}"
                              SelectedIndex="{Binding Default.SelectedTransition, Source={StaticResource Settings}}"
                              ItemsSource="{x:Static transitions:TransitionCollection.Transitions}"
                              MinWidth="200" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- ══ License card ══════════════════════════════════ -->
            <Border Style="{StaticResource WinPanel}" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="License" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,14" />
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Ink2Brush}" FontSize="12.5" Margin="0,0,0,6">
                        Created by © 2022 sabihoshi under the
                        <Hyperlink NavigateUri="{Binding Default.LicenseUri, Source={StaticResource Settings}}">MIT License</Hyperlink>.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Ink3Brush}" FontSize="12">
                        Uses third-party libraries under
                        <Hyperlink NavigateUri="{Binding Default.ThirdPartyLicenseUri, Source={StaticResource Settings}}">different licenses</Hyperlink>.
                        All rights reserved by © miHoYo Co., Ltd. Not affiliated with miHoYo.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
