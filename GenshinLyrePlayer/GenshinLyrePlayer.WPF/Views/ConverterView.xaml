<UserControl
    x:Class="GenshinLyreMidiPlayer.WPF.Views.ConverterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:viewModels="clr-namespace:GenshinLyreMidiPlayer.WPF.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:ConverterViewModel}">

    <UserControl.Resources>
        <!-- ── Minimal ProgressBar style matching Windsong palette ── -->
        <Style x:Key="ConvProgressBar" TargetType="ProgressBar">
            <Setter Property="Minimum"         Value="0" />
            <Setter Property="Maximum"         Value="100" />
            <Setter Property="Height"          Value="8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#A68A22" Offset="0" />
                        <GradientStop Color="#D6BC5C" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{StaticResource Bg3Brush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="999" Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Grid>
                                <Rectangle x:Name="PART_Track" />
                                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" />
                                </Decorator>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Indeterminate: stretch to show a solid gold bar -->
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="HorizontalAlignment" Value="Stretch" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Page header ────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="TOOLS" Style="{StaticResource EyebrowStyle}" />
            <TextBlock Text="Video Converter" Style="{StaticResource PageTitleStyle}" />
        </StackPanel>

        <!-- ── Body ──────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ════════════════════════════════════════
                     Input panel
                     ════════════════════════════════════════ -->
                <Border Style="{StaticResource WinPanel}" Padding="18,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="INPUT" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,12" />

                        <!-- Video file -->
                        <TextBlock Text="Video file"
                                   FontSize="12" Foreground="{StaticResource Ink3Brush}" Margin="0,0,0,5" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding VideoPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource WinTextBox}"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1" Command="{s:Action BrowseVideo}"
                                    Style="{StaticResource WinBtn}" Height="38" Padding="14,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Browse" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Output file -->
                        <TextBlock Text="Output .txt file"
                                   FontSize="12" Foreground="{StaticResource Ink3Brush}" Margin="0,0,0,5" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource WinTextBox}"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1" Command="{s:Action BrowseOutput}"
                                    Style="{StaticResource WinBtn}" Height="38" Padding="14,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Browse" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Options -->
                        <DockPanel Margin="0,0,0,18">
                            <CheckBox DockPanel.Dock="Right" Content="Debug logging"
                                      IsChecked="{Binding DebugMode}"
                                      Style="{StaticResource WinToggle}"
                                      VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="BPM override"
                                           FontSize="12.5" Foreground="{StaticResource Ink3Brush}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Text="{Binding BpmText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource WinTextBox}" Width="80" />
                                <TextBlock Text="(empty = auto)"
                                           FontSize="11.5" Foreground="{StaticResource Ink4Brush}"
                                           VerticalAlignment="Center" Margin="10,0,0,0" />
                            </StackPanel>
                        </DockPanel>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{s:Action Convert}"
                                    IsEnabled="{Binding CanConvert}"
                                    Style="{StaticResource AccentBtn}" Height="38" Padding="20,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Convert" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{s:Action Cancel}"
                                    Visibility="{Binding IsConverting,
                                        Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                    Style="{StaticResource GhostBtn}"
                                    Height="38" Padding="14,0" Margin="8,0,0,0"
                                    Foreground="{StaticResource DangerBrush}">
                                Cancel
                            </Button>
                            <Button Command="{s:Action Reset}"
                                    Visibility="{Binding ConvertDone,
                                        Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                    Style="{StaticResource GhostBtn}"
                                    Height="38" Padding="14,0" Margin="8,0,0,0"
                                    Foreground="{StaticResource Ink3Brush}">
                                Reset
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════
                     Progress + Log + Result (shown while running or when done)
                     ════════════════════════════════════════ -->
                <Border Style="{StaticResource WinPanel}" Padding="18,14" Margin="0,0,0,12"
                        Visibility="{Binding ShowLog,
                            Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                    <StackPanel>

                        <!-- Progress bar row (visible while converting) -->
                        <StackPanel Margin="0,0,0,14"
                                    Visibility="{Binding IsConverting,
                                        Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                            <TextBlock Text="PROGRESS" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,8" />
                            <ProgressBar
                                Value="{Binding ProgressValue, Mode=OneWay}"
                                IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                                Style="{StaticResource ConvProgressBar}"
                                Margin="0,0,0,6" />
                            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                       FontSize="11.5" Foreground="{StaticResource Ink3Brush}" />
                        </StackPanel>

                        <!-- Log TextBox (single instance, always in this panel) -->
                        <TextBlock Text="OUTPUT LOG" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,8" />
                        <TextBox x:Name="LogBox"
                                 Text="{Binding LogOutput, Mode=OneWay}"
                                 TextChanged="LogBox_TextChanged"
                                 Style="{StaticResource WinTextBoxMulti}"
                                 IsReadOnly="True"
                                 Height="190"
                                 Background="{StaticResource Bg2Brush}"
                                 Padding="14,12"
                                 FontSize="12"
                                 VerticalScrollBarVisibility="Auto" />

                        <!-- Result row (visible when done) -->
                        <DockPanel Margin="0,14,0,0"
                                   Visibility="{Binding ConvertDone,
                                       Converter={x:Static s:BoolToVisibilityConverter.Instance}}">

                            <!-- Status icon + message -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="&#xE73E;" />
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConvertSuccess}" Value="False">
                                                    <Setter Property="Text"       Value="&#xE711;" />
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                           FontSize="13" Foreground="{StaticResource InkBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Action buttons (on success only) -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        Visibility="{Binding ShowResult,
                                            Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                <Button Command="{s:Action OpenInEditor}"
                                        Style="{StaticResource WinBtn}"
                                        Height="34" Padding="14,0" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Open in Editor" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{s:Action AddToPlaylist}"
                                        Style="{StaticResource AccentBtn}"
                                        Height="34" Padding="14,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Add to Playlist" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>

                        <!-- Final progress bar (on completion) -->
                        <ProgressBar
                            Value="{Binding ProgressValue, Mode=OneWay}"
                            IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                            Style="{StaticResource ConvProgressBar}"
                            Margin="0,10,0,0"
                            Visibility="{Binding ConvertDone,
                                Converter={x:Static s:BoolToVisibilityConverter.Instance}}" />
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════
                     How-it-works hint (before first run)
                     ════════════════════════════════════════ -->
                <Border Style="{StaticResource WinPanelSm}" Padding="18,14"
                        Visibility="{Binding ShowLog,
                            Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}">
                    <StackPanel>
                        <TextBlock Text="HOW IT WORKS" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,10" />
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="{StaticResource Ink2Brush}"
                                   LineHeight="20">
                            <Run FontWeight="Medium">1.</Run>
                            <Run Foreground="{StaticResource AccentBrush}" FontWeight="Medium">Browse</Run>
                            <Run>a video of yourself playing the Windsong Lyre in Genshin Impact.</Run>
                            <LineBreak />
                            <Run FontWeight="Medium">2.</Run>
                            <Run>Set a BPM override if the auto-detection gives wrong note lengths.</Run>
                            <LineBreak />
                            <Run FontWeight="Medium">3.</Run>
                            <Run>Click</Run>
                            <Run Foreground="{StaticResource AccentBrush}" FontWeight="Medium">Convert</Run>
                            <Run>— the vision parser analyses each frame and extracts which keys were pressed.</Run>
                            <LineBreak />
                            <Run FontWeight="Medium">4.</Run>
                            <Run>When done, open the result in the</Run>
                            <Run Foreground="{StaticResource AccentBrush}">Editor</Run>
                            <Run>to clean it up, or add it straight to your</Run>
                            <Run Foreground="{StaticResource AccentBrush}">Playlist</Run>
                            <Run>to play it back.</Run>
                        </TextBlock>
                        <Border Margin="0,14,0,0" Padding="14,10" CornerRadius="8"
                                Background="{StaticResource Bg3Brush}">
                            <TextBlock FontSize="11.5" Foreground="{StaticResource Ink4Brush}" TextWrapping="Wrap">
                                <Run FontWeight="Medium" Foreground="{StaticResource Ink3Brush}">Requires Python —</Run>
                                <Run>install once with</Run>
                                <Run FontFamily="Consolas, 'Courier New', monospace"
                                     Foreground="{StaticResource AccentBrightBrush}">pip install -e .</Run>
                                <Run>from the GenshinMusic folder, or make sure</Run>
                                <Run FontFamily="Consolas, 'Courier New', monospace"
                                     Foreground="{StaticResource AccentBrightBrush}">genshin-parse</Run>
                                <Run>is on your PATH.</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
