<UserControl
    x:Class="GenshinLyreMidiPlayer.WPF.Views.LyrePlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:core="clr-namespace:GenshinLyreMidiPlayer.WPF.Core"
    xmlns:viewModels="clr-namespace:GenshinLyreMidiPlayer.WPF.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:LyrePlayerViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Page header ────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="NOW PLAYING" Style="{StaticResource EyebrowStyle}" />
            <TextBlock Text="Player" Style="{StaticResource PageTitleStyle}" />
        </StackPanel>

        <!-- ── Now playing card ───────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource WinPanel}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Art box -->
                <Border Grid.Column="0" Width="96" Height="96" CornerRadius="12" Margin="0,0,20,0"
                        ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3A3220" Offset="0" />
                            <GradientStop Color="#1E1A10" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Viewbox Width="62" Height="62">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="#C9A93C" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 5.5C6 12 7.5 17 9.5 19.5" />
                            <Path Stroke="#C9A93C" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M18 5.5C18 12 16.5 17 14.5 19.5" />
                            <Path Stroke="#C9A93C" StrokeThickness="1.7" Opacity="0.75"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M9 6.5h6 M8.4 10h7.2 M8.6 13.5h6.8" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- Song info + transport -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Title -->
                    <TextBlock
                        Text="{Binding Playlist.OpenedFile.Title, FallbackValue='Open a MIDI file to begin'}"
                        FontSize="16" FontWeight="SemiBold" Foreground="#EDE9DC"
                        TextTrimming="CharacterEllipsis" />
                    <!-- Subtitle -->
                    <TextBlock
                        Text="MIDI File" FontSize="12" Foreground="#6A6358" Margin="0,3,0,16" />

                    <!-- Transport row -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Shuffle -->
                        <Button s:View.ActionTarget="{Binding Playlist}"
                                Command="{s:Action ToggleShuffle}"
                                Style="{StaticResource IconBtn}"
                                ToolTip="Shuffle">
                            <TextBlock Text="&#xE14B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{Binding Playlist.ShuffleStateColor}" />
                        </Button>

                        <!-- Prev -->
                        <Button Command="{s:Action Previous}"
                                IsHitTestVisible="{Binding CanHitPrevious}"
                                Style="{StaticResource IconBtn}"
                                Margin="6,0,0,0" ToolTip="Previous">
                            <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                        </Button>

                        <!-- Play/Pause (round gold) -->
                        <Button Command="{s:Action PlayPause}"
                                IsHitTestVisible="{Binding CanHitPlayPause}"
                                Style="{StaticResource PlayBtn}"
                                Margin="8,0" ToolTip="Play / Pause">
                            <TextBlock Text="{Binding PlayPauseIcon}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{StaticResource AccentInkBrush}"
                                       Margin="3,0,0,0" />
                        </Button>

                        <!-- Next -->
                        <Button Command="{s:Action Next}"
                                IsHitTestVisible="{Binding CanHitNext}"
                                Style="{StaticResource IconBtn}" ToolTip="Next">
                            <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                        </Button>

                        <!-- Loop -->
                        <Button s:View.ActionTarget="{Binding Playlist}"
                                Command="{s:Action ToggleLoop}"
                                Style="{StaticResource IconBtn}"
                                Margin="6,0,0,0" ToolTip="Loop">
                            <TextBlock Text="{Binding Playlist.LoopStateString}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="18" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Progress bar ────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding CurrentTime, StringFormat=m\\:ss}"
                       Foreground="{StaticResource Ink3Brush}" FontSize="11.5"
                       VerticalAlignment="Center" />
            <Slider Grid.Column="1"
                    Style="{StaticResource WinSlider}"
                    Value="{Binding SongPosition}"
                    Maximum="{Binding MaximumTime.TotalSeconds}"
                    IsEnabled="{Binding CanHitPlayPause}" />
            <TextBlock Grid.Column="2" Text="{Binding MaximumTime, StringFormat=m\\:ss}"
                       Foreground="{StaticResource Ink3Brush}" FontSize="11.5"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- ── MIDI Tracks / Token Visualizer (swap based on file type) ── -->
        <Grid Grid.Row="3" Margin="0,20,0,0">

            <!-- ════ MIDI Tracks panel (shown for .mid/.midi files) ════ -->
            <Border Style="{StaticResource WinPanel}" Padding="18,14"
                    Visibility="{Binding IsPlayingTxtFile,
                                 Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}">
                <DockPanel LastChildFill="True">
                    <!-- Section header + open-file button -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="MIDI Tracks" Style="{StaticResource SectionLabelStyle}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Command="{s:Action OpenFile}"
                                Style="{StaticResource GhostBtn}" Height="32" Padding="12,0"
                                HorizontalAlignment="Right" Foreground="{StaticResource Ink3Brush}"
                                ToolTip="Open MIDI file">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Open" FontSize="12.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <!-- Track list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MidiTracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="14,9" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left"
                                                      IsChecked="{Binding IsChecked}"
                                                      IsEnabled="{Binding CanBePlayed}"
                                                      Style="{StaticResource TrackToggle}"
                                                      Margin="0,0,12,0" VerticalAlignment="Center">
                                                <CheckBox.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock Text="Cannot disable track containing tempo settings."
                                                                   Visibility="{Binding CanBePlayed, Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}" />
                                                    </ToolTip>
                                                </CheckBox.ToolTip>
                                            </CheckBox>
                                            <TextBlock Text="{Binding TrackName, TargetNullValue=Unknown}"
                                                       Foreground="{StaticResource InkBrush}"
                                                       FontSize="13" VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ════ Token Visualizer panel (shown for .txt files) ════ -->
            <Border Style="{StaticResource WinPanel}" Padding="18,14"
                    Visibility="{Binding IsPlayingTxtFile,
                                 Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                <DockPanel LastChildFill="True">

                    <!-- Section header -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Token Stream" Style="{StaticResource SectionLabelStyle}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Command="{s:Action OpenFile}"
                                Style="{StaticResource GhostBtn}" Height="32" Padding="12,0"
                                Foreground="{StaticResource Ink3Brush}" ToolTip="Open file">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Open" FontSize="12.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <!-- ── Full-song token stream — horizontally scrollable ────── -->
                    <!-- SelectedItem drives auto-scroll via code-behind            -->
                    <ListBox x:Name="TokenStream"
                             ItemsSource="{Binding AllTokens}"
                             SelectedItem="{Binding CurrentTokenVM, Mode=OneWay}"
                             SelectionMode="Single"
                             SelectionChanged="TokenStream_SelectionChanged"
                             PreviewMouseWheel="TokenStream_PreviewMouseWheel"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             Background="{StaticResource Bg0Brush}"
                             BorderThickness="0"
                             Padding="6"
                             Focusable="False">
                        <!-- Suppress the default selection highlight — we draw our own -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"    Value="0" />
                                <Setter Property="Margin"     Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type core:VisualTokenViewModel}">
                                <Border Padding="9,5" Margin="2,4" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"   Value="Transparent" />
                                            <Setter Property="CornerRadius" Value="7" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}"
                                                             Value="{x:Static core:VisualTokenState.Current}">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#D6BC5C" Offset="0" />
                                                                <GradientStop Color="#C9A93C" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Display}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize"   Value="13" />
                                                <Setter Property="Foreground" Value="{StaticResource Ink2Brush}" />
                                                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}"
                                                                 Value="{x:Static core:VisualTokenState.Past}">
                                                        <Setter Property="Foreground" Value="{StaticResource Ink4Brush}" />
                                                        <Setter Property="FontSize"   Value="11" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}"
                                                                 Value="{x:Static core:VisualTokenState.Current}">
                                                        <Setter Property="Foreground" Value="#1D1A16" />
                                                        <Setter Property="FontSize"   Value="14" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>

        </Grid>

        <!-- ── MIDI Input Device ───────────────────────────── -->
        <Border Grid.Row="4" Style="{StaticResource WinPanelSm}" Padding="16,12" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Input Device"
                           FontSize="12.5" FontWeight="SemiBold"
                           Foreground="{StaticResource Ink2Brush}"
                           VerticalAlignment="Center" Margin="0,0,14,0" />
                <Button DockPanel.Dock="Right" Command="{s:Action RefreshDevices}"
                        Style="{StaticResource IconBtn}" Margin="8,0,0,0"
                        ToolTip="Refresh MIDI devices">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                </Button>
                <ComboBox ItemsSource="{Binding MidiInputs}"
                          SelectedItem="{Binding SelectedMidiInput}"
                          DisplayMemberPath="DeviceName"
                          VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
